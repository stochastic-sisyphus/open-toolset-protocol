{
  "$schema": "https://open-toolset-protocol.org/schemas/toolsets.schema.json",
  "toolset_name": "codex-default",
  "version": "0.1.0",
  "description": "OATP toolset for Codex CLI agents. Flat tool list, full phase gating and capability negotiation, explicit deny policies.",
  "capabilities": {
    "discovery": true,
    "phase_gating": true,
    "capability_negotiation": true,
    "state_attestation": false
  },
  "phases": ["reconnaissance", "surgery", "instrumentation"],
  "policies": {
    "default_action": "deny",
    "allow": ["rg-search", "find-read", "git-read", "node-script", "python-script", "mise-run", "git-diff-verify"],
    "deny": ["npm-global", "pip-install", "brew-install", "cargo-install"],
    "banned_patterns": [
      "npm\\s+(install|i)\\s+(-g|--global)",
      "pip\\s+install(?!\\s+(-r|--requirement))",
      "pip3\\s+install",
      "brew\\s+(install|upgrade)",
      "cargo\\s+install",
      "sudo\\s+",
      "rm\\s+-rf\\s+/",
      "chmod\\s+777",
      "curl\\s+.*\\|\\s*(ba)?sh",
      "wget\\s+.*\\|\\s*(ba)?sh"
    ]
  },
  "tools": [
    {
      "name": "rg-search",
      "phase": "reconnaissance",
      "category": "index-search",
      "verification_mode": "deterministic",
      "description": "Ripgrep file search.",
      "binary_repo": "https://github.com/BurntSushi/ripgrep",
      "operational_constraints": ["read-only"],
      "required": true
    },
    {
      "name": "find-read",
      "phase": "reconnaissance",
      "category": "index-search",
      "verification_mode": "deterministic",
      "description": "Filesystem find. Read-only.",
      "operational_constraints": ["read-only", "no exec"]
    },
    {
      "name": "git-read",
      "phase": "reconnaissance",
      "category": "navigation",
      "verification_mode": "deterministic",
      "description": "Read-only git operations.",
      "operational_constraints": ["read-only"]
    },
    {
      "name": "node-script",
      "phase": "surgery",
      "category": "logic-substrate",
      "verification_mode": "heuristic",
      "description": "Node.js script execution for transformation tasks.",
      "operational_constraints": ["no network", "project-local only"]
    },
    {
      "name": "python-script",
      "phase": "surgery",
      "category": "logic-substrate",
      "verification_mode": "heuristic",
      "description": "Python script execution for transformation tasks.",
      "operational_constraints": ["no network", "project-local only"]
    },
    {
      "name": "mise-run",
      "phase": "surgery",
      "category": "config-substrate",
      "verification_mode": "heuristic",
      "description": "Task runner for project build and test tasks.",
      "operational_constraints": ["project-local only"]
    },
    {
      "name": "git-diff-verify",
      "phase": "instrumentation",
      "category": "merge-diff",
      "verification_mode": "deterministic",
      "description": "Verify changes via git diff before commit.",
      "operational_constraints": ["read-only"],
      "required": true
    }
  ]
}
