{
  "$schema": "https://open-toolset-protocol.org/schemas/toolsets.schema.json",
  "version": "0.1",
  "name": "codex-default",
  "description": "OATP toolset for Codex CLI. Allows file operations, read-only git, and shell exec within project scope. Bans global installs and destructive filesystem ops.",
  "tools": [
    {
      "id": "rg-search",
      "command": "rg",
      "description": "Ripgrep file search.",
      "args_pattern": {
        "deny": "--(write|replace|passthru)"
      },
      "timeout": 30
    },
    {
      "id": "find-read",
      "command": "find",
      "description": "Filesystem find. Read-only, scoped to project.",
      "args_pattern": {
        "deny": "(-delete|-exec\\s+rm|-exec\\s+mv)"
      },
      "cwd_constraint": "^(/Users|/home|/workspace)",
      "timeout": 30
    },
    {
      "id": "git-read",
      "command": "git",
      "description": "Read-only git operations.",
      "args_pattern": {
        "allow": "^(status|diff|log|show|blame|branch|remote|tag|shortlog|describe|rev-parse|ls-files|ls-tree)(\\s|$)"
      },
      "timeout": 30
    },
    {
      "id": "node-script",
      "command": "node",
      "description": "Node.js script execution.",
      "args_pattern": {
        "deny": "--eval"
      },
      "timeout": 60
    },
    {
      "id": "python-script",
      "command": "python3",
      "description": "Python script execution.",
      "args_pattern": {
        "deny": "-c\\s"
      },
      "timeout": 60
    },
    {
      "id": "mise-run",
      "command": "mise",
      "description": "mise task runner.",
      "args_pattern": {
        "allow": "^(run|exec|tasks)(\\s|$)"
      },
      "timeout": 120
    }
  ],
  "policies": {
    "default_action": "deny",
    "default_timeout": 60,
    "banned_patterns": [
      "npm\\s+(install|i)\\s+(-g|--global)",
      "pip\\s+install(?!\\s+(-r|--requirement))",
      "pip3\\s+install",
      "brew\\s+(install|upgrade)",
      "cargo\\s+install",
      "sudo\\s+",
      "rm\\s+-rf\\s+/",
      "chmod\\s+777",
      "curl\\s+.*\\|\\s*(ba)?sh",
      "wget\\s+.*\\|\\s*(ba)?sh"
    ],
    "path_denylist": [
      "~/.ssh/**",
      "~/.gnupg/**",
      "/etc/passwd",
      "/etc/shadow"
    ]
  },
  "instrumentation": {
    "trace_events": true,
    "event_sink": "~/.local/share/oatp/codex.jsonl",
    "redact_secrets": true
  },
  "redaction": {
    "patterns": [
      {
        "name": "api-key",
        "regex": "(sk-|ghp_|gho_|AKIA)[A-Za-z0-9_\\-]{16,}",
        "replacement": "[REDACTED:api-key]"
      },
      {
        "name": "env-secret",
        "regex": "(?i)(password|secret|token|api_key)\\s*=\\s*\\S+",
        "replacement": "[REDACTED:secret]"
      }
    ]
  }
}
