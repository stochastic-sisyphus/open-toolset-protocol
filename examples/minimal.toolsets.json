{
  "$schema": "https://open-toolset-protocol.org/schemas/toolsets.schema.json",
  "toolset_name": "minimal",
  "version": "0.1.0",
  "description": "Smallest valid OATP registry. Allows read-only file search during reconnaissance, denies everything else.",
  "capabilities": {
    "discovery": true,
    "phase_gating": true,
    "capability_negotiation": false,
    "state_attestation": false
  },
  "phases": [
    "reconnaissance"
  ],
  "policies": {
    "default_action": "deny",
    "allow": [
      "ls",
      "cat"
    ],
    "deny": [],
    "forbidden_args": []
  },
  "tools": [
    {
      "name": "rg-search",
      "phase": "reconnaissance",
      "category": "index-search",
      "verification_mode": "deterministic",
      "description": "Read-only file search.",
      "operational_constraints": [
        "read-only"
      ],
      "priority": 80
    }
  ]
}
